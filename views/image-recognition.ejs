<style>
    /* Privacy Blur Styles */
    .blurred-image {
        filter: blur(20px);
        transition: filter 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        transform: scale(1.05); /* Slight scale to prevent edge bleed */
    }

    .blurred-image.revealed {
        filter: blur(0);
        transform: scale(1);
    }

    /* Reveal Confirmation Modal */
    .reveal-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(8px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 10001;
        padding: 1.5rem;
    }

    .reveal-modal-content {
        background: var(--surface-glass, #ffffff);
        border: 1px solid var(--border-glass, rgba(255,255,255,0.1));
        border-radius: 1.25rem;
        padding: 2rem;
        max-width: 400px;
        width: 100%;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        text-align: center;
    }

    .reveal-btn {
        padding: 0.75rem 1.5rem;
        border-radius: 0.75rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-size: 0.9rem;
    }

    .reveal-btn-yes {
        background: var(--primary-gradient, #4f46e5);
        color: white;
    }

    .reveal-btn-no {
        background: rgba(255, 255, 255, 0.1);
        color: var(--text-heading, #fff);
        margin-left: 0.5rem;
    }

    .reveal-btn:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }
</style>

<div class="page-container">
    <div class="page-header">
        <div>
            <h1>Visual Profiles</h1>
            <p style="color: var(--text-muted); font-size: 0.9rem;">
                Remote photo verification with timestamps, grouped per employee without duplicate images.
            </p>
        </div>
        <div class="search-wrapper">
            <i data-lucide="search"></i>
            <input type="text" id="folderSearch" placeholder="Filter by name...">
        </div>
    </div>

    <% if (typeof users !== 'undefined' && users.length > 0) { %>
        <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <% users.forEach(user => { %>
                <details class="employee-folder card" style="padding: 0; overflow: hidden;"
                    <%= user.photos && user.photos.length > 0 ? 'open' : '' %>
                    data-name="<%= (user.name || '').toLowerCase() %>">

                    <summary
                        class="employee-folder__summary"
                        style="width: 100%; padding: 1.25rem 1.5rem; display: flex; align-items: center; justify-content: space-between; cursor: pointer; border-bottom: 1px solid transparent; transition: background 0.2s; background: transparent; text-align: left; list-style: none;"
                    >
                        <div style="display: flex; align-items: center; gap: 1rem;">
                            <div
                                style="width: 42px; height: 42px; border-radius: 50%; background: var(--primary-gradient); color: white; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; font-weight: 800; flex-shrink: 0;">
                                <%= user.name ? user.name.charAt(0).toUpperCase() : '?' %>
                            </div>
                            <div>
                                <div style="font-weight: 700; color: var(--text-heading);">
                                    <%= user.name || 'Unknown' %>
                                </div>
                                <div
                                    style="font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">
                                    <%= user.role || 'Personnel' %> &nbsp;|&nbsp;
                                    <span class="photo-count" style="color: var(--accent-indigo); font-weight: 700;">
                                        <%= (user.photos && user.photos.length) || 0 %> photo<%= (user.photos && user.photos.length !== 1) ? 's' : '' %>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="folder-chevron" style="color: var(--text-muted); transition: transform 0.3s;">
                            <i data-lucide="chevron-down" style="width: 20px; height: 20px;"></i>
                        </div>
                    </summary>

                    <div class="folder-content" style="padding: 1.5rem;">
                        <% if (user.photos && user.photos.length > 0) { %>
                            <div
                                style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1rem;">
                                <% user.photos.forEach(photo => { %>
                                    <button type="button"
                                        class="image-card-button"
                                        data-photo-key="<%= photo.photoKey || '' %>"
                                        data-lightbox-label='<%- JSON.stringify(`${user.name || "Employee"} - ${photo.label}`) %>'
                                        style="position: relative; border-radius: 12px; overflow: hidden; border: 1px solid var(--border-glass); cursor: pointer; padding: 0; background: transparent; width: 100%;">
                                        <img src="<%= photo.path %>" alt="<%= photo.label %>" loading="lazy" class="blurred-image"
                                            data-photo-key="<%= photo.photoKey || '' %>"
                                            data-fallbacks='<%- JSON.stringify(photo.sources || [photo.path]) %>'
                                            style="width: 100%; height: 160px; object-fit: cover; display: block; transition: transform 0.3s;"
                                            onerror="handleImageFallback(this)"
                                        >
                                        <div
                                            style="position: absolute; bottom: 0; left: 0; right: 0; padding: 0.5rem 0.75rem; background: linear-gradient(to top, rgba(0,0,0,0.75), transparent);">
                                            <% if (String(photo.label || '').toLowerCase().includes('profile')) { %>
                                                <span
                                                    style="font-size: 0.65rem; font-weight: 800; color: #a78bfa; text-transform: uppercase; letter-spacing: 0.08em;">
                                                    <%= photo.label %>
                                                </span>
                                            <% } else { %>
                                                <span
                                                    style="font-size: 0.62rem; font-weight: 700; color: rgba(255,255,255,0.85);">
                                                    <%= photo.label %>
                                                </span>
                                            <% } %>
                                        </div>
                                    </button>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div
                                style="padding: 3rem; text-align: center; border: 2px dashed var(--border-glass); border-radius: 12px; color: var(--text-muted);">
                                <i data-lucide="image-off"
                                    style="width: 32px; height: 32px; opacity: 0.25; margin-bottom: 0.75rem;"></i>
                                <p
                                    style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;">
                                    No remote photos synced yet
                                </p>
                            </div>
                        <% } %>
                    </div>
                </details>
            <% }) %>
        </div>
    <% } else { %>
        <div
            style="padding: 6rem; text-align: center; background: var(--surface-glass); border: 2px dashed var(--border-glass); border-radius: 1.5rem;">
            <i data-lucide="database-zap"
                style="width: 48px; height: 48px; color: var(--text-muted); margin-bottom: 1.5rem; opacity: 0.2;"></i>
            <p
                style="color: var(--text-muted); font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">
                No employees found in database.
            </p>
        </div>
    <% } %>
</div>

<!-- Reveal Confirmation Modal -->
<div id="reveal-modal-overlay" class="reveal-modal-overlay">
    <div class="reveal-modal-content">
        <div style="margin-bottom: 1.5rem; color: var(--accent-indigo, #6366f1);">
            <i data-lucide="eye-off" style="width: 48px; height: 48px; margin: 0 auto;"></i>
        </div>
        <h3 style="margin-bottom: 0.5rem; color: var(--text-heading);">View Profile Image?</h3>
        <p style="margin-bottom: 2rem; color: var(--text-muted); font-size: 0.9rem;">Do you want to see the image?</p>
        <div style="display: flex; justify-content: center; gap: 0.75rem;">
            <button type="button" id="confirm-reveal-yes" class="reveal-btn reveal-btn-yes">Yes, Reveal</button>
            <button type="button" id="confirm-reveal-no" class="reveal-btn reveal-btn-no">No</button>
        </div>
    </div>
</div>

<div id="lightbox"
    style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.9); z-index:9999; align-items:center; justify-content:center; flex-direction:column; gap:1rem;">
    <button type="button" id="lightbox-close"
        style="position:absolute; top:1.5rem; right:2rem; color:white; font-size:2rem; cursor:pointer; line-height:1; background:transparent; border:none; width:48px; height:48px; border-radius:999px; display:inline-flex; align-items:center; justify-content:center;">
        &times;
    </button>
    <img id="lightbox-img" src="" alt=""
        style="max-width:90vw; max-height:80vh; border-radius:12px; object-fit:contain; box-shadow: 0 0 60px rgba(0,0,0,0.5);">
    <p id="lightbox-label" style="color:white; font-size:0.85rem; font-weight:600; text-align:center; opacity:0.8;"></p>
</div>

<script>
    const IMAGE_GALLERY_CACHE_KEY = 'image-recognition-gallery-v1';
    const IMAGE_SOURCE_CACHE_KEY = 'image-recognition-resolved-sources-v1';
    const MAX_IMAGE_CACHE_ENTRIES = 1200;

    function safeReadJsonFromLocalStorage(key, fallbackValue) {
        try {
            const raw = window.localStorage.getItem(key);
            if (!raw) return fallbackValue;
            return JSON.parse(raw);
        } catch (error) {
            return fallbackValue;
        }
    }

    function safeWriteJsonToLocalStorage(key, value) {
        try {
            window.localStorage.setItem(key, JSON.stringify(value));
        } catch (error) {
            // Ignore storage quota and serialization errors.
        }
    }

    function readResolvedSourceCache() {
        const parsed = safeReadJsonFromLocalStorage(IMAGE_SOURCE_CACHE_KEY, {});
        if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return {};
        return parsed;
    }

    function writeResolvedSourceCache(cache) {
        const entries = Object.entries(cache || {});
        const trimmed = entries.slice(Math.max(0, entries.length - MAX_IMAGE_CACHE_ENTRIES));
        safeWriteJsonToLocalStorage(IMAGE_SOURCE_CACHE_KEY, Object.fromEntries(trimmed));
    }

    function getImageKey(imageElement) {
        if (!imageElement) return '';
        const explicitKey = String(imageElement.dataset.photoKey || '').trim();
        if (explicitKey) return explicitKey;

        const src = String(imageElement.currentSrc || imageElement.src || '').trim();
        if (!src) return '';
        return src.split('#')[0].split('?')[0].toLowerCase();
    }

    function openLightbox(src, label) {
        document.getElementById('lightbox-img').src = src;
        document.getElementById('lightbox-label').textContent = label;
        document.getElementById('lightbox').style.display = 'flex';
    }

    function openLightboxFromCard(card, label) {
        const image = card.querySelector('img');
        if (!image) return;
        openLightbox(image.currentSrc || image.src, label);
    }

    function handleImageFallback(image) {
        const placeholder = 'data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22360%22 height=%22240%22 viewBox=%220 0 360 240%22%3E%3Crect width=%22360%22 height=%22240%22 fill=%22%23f8fafc%22/%3E%3Cpath d=%22M108 156l40-48 31 37 21-26 52 63H108z%22 fill=%22%23cbd5e1%22/%3E%3Ccircle cx=%22145%22 cy=%2288%22 r=%2214%22 fill=%22%23cbd5e1%22/%3E%3Ctext x=%22180%22 y=%22208%22 text-anchor=%22middle%22 font-family=%22Arial, sans-serif%22 font-size=%2216%22 fill=%2264758b%22%3EImage unavailable%3C/text%3E%3C/svg%3E';

        let fallbacks = [];
        try {
            fallbacks = JSON.parse(image.dataset.fallbacks || '[]');
        } catch (error) {
            fallbacks = [];
        }

        const currentIndex = Number(image.dataset.fallbackIndex || '0');
        const nextIndex = currentIndex + 1;

        if (nextIndex < fallbacks.length) {
            image.dataset.fallbackIndex = String(nextIndex);
            image.src = fallbacks[nextIndex];
            return;
        }

        const cache = readResolvedSourceCache();
        const cachedSource = cache[getImageKey(image)];
        if (cachedSource && cachedSource !== image.src) {
            image.src = cachedSource;
            return;
        }

        image.onerror = null;
        image.src = placeholder;
    }

    function closeLightbox() {
        document.getElementById('lightbox').style.display = 'none';
        document.getElementById('lightbox-img').src = '';
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
    });

    document.addEventListener('DOMContentLoaded', () => {
        lucide.createIcons();
        const lightbox = document.getElementById('lightbox');
        const lightboxImage = document.getElementById('lightbox-img');
        const lightboxClose = document.getElementById('lightbox-close');
        const resolvedSourceCache = readResolvedSourceCache();
        
        // Reveal Modal Elements
        const revealModal = document.getElementById('reveal-modal-overlay');
        const confirmYes = document.getElementById('confirm-reveal-yes');
        const confirmNo = document.getElementById('confirm-reveal-no');
        let pendingImage = null;

        const dedupeRenderedCards = () => {
            document.querySelectorAll('.employee-folder').forEach((folder) => {
                const seenKeys = new Set();

                folder.querySelectorAll('.image-card-button').forEach((button) => {
                    const image = button.querySelector('img');
                    if (!image) return;

                    const key = getImageKey(image);
                    if (!key) return;

                    if (seenKeys.has(key)) {
                        button.remove();
                        return;
                    }

                    seenKeys.add(key);
                });
            });
        };

        const refreshFolderPhotoCounts = () => {
            document.querySelectorAll('.employee-folder').forEach((folder) => {
                const count = folder.querySelectorAll('.image-card-button').length;
                const countLabel = folder.querySelector('.photo-count');
                if (countLabel) {
                    countLabel.textContent = `${count} photo${count === 1 ? '' : 's'}`;
                }
            });
        };

        dedupeRenderedCards();
        refreshFolderPhotoCounts();

        const folderSearch = document.getElementById('folderSearch');
        if (folderSearch) {
            folderSearch.addEventListener('input', function () {
                const q = this.value.toLowerCase().trim();
                document.querySelectorAll('.employee-folder').forEach(folder => {
                    folder.style.display = folder.dataset.name.includes(q) ? '' : 'none';
                });
            });
        }

        // Reveal Modal Handlers
        const closeRevealModal = () => {
            revealModal.style.display = 'none';
            pendingImage = null;
        };

        confirmYes.addEventListener('click', () => {
            if (pendingImage) {
                pendingImage.classList.remove('blurred-image');
                pendingImage.classList.add('revealed');
            }
            closeRevealModal();
        });

        confirmNo.addEventListener('click', closeRevealModal);
        
        revealModal.addEventListener('click', (e) => {
            if (e.target === revealModal) closeRevealModal();
        });

        document.querySelectorAll('.image-card-button').forEach((button) => {
            button.addEventListener('click', (event) => {
                event.stopPropagation();
                const img = button.querySelector('img');

                // If image is still blurred, prompt for reveal
                if (img && img.classList.contains('blurred-image') && !img.classList.contains('revealed')) {
                    pendingImage = img;
                    revealModal.style.display = 'flex';
                    return;
                }

                // Otherwise, open standard lightbox
                openStandardLightbox(button);
            });
        });

        function openStandardLightbox(button) {
            let label = 'Employee photo';
            try {
                label = JSON.parse(button.dataset.lightboxLabel || '"Employee photo"');
            } catch (error) {
                label = button.dataset.lightboxLabel || 'Employee photo';
            }
            openLightboxFromCard(button, label);
        }

        document.querySelectorAll('.image-card-button img').forEach((image) => {
            const key = getImageKey(image);
            if (!key) return;

            const cachedSource = resolvedSourceCache[key];
            if (cachedSource) {
                let fallbacks = [];
                try {
                    fallbacks = JSON.parse(image.dataset.fallbacks || '[]');
                } catch (error) {
                    fallbacks = [];
                }

                if (!fallbacks.includes(cachedSource)) {
                    fallbacks.push(cachedSource);
                    image.dataset.fallbacks = JSON.stringify(fallbacks);
                }
            }

            image.addEventListener('load', () => {
                const source = String(image.currentSrc || image.src || '').trim();
                if (!source) return;

                const currentCache = readResolvedSourceCache();
                currentCache[key] = source;
                writeResolvedSourceCache(currentCache);
            }, { once: true });
        });

        const gallerySnapshot = Array.from(document.querySelectorAll('.image-card-button')).map((button) => {
            const image = button.querySelector('img');
            if (!image) return null;

            const src = String(image.currentSrc || image.src || '').trim();
            if (!src) return null;

            let label = 'Employee photo';
            try {
                label = JSON.parse(button.dataset.lightboxLabel || '"Employee photo"');
            } catch (error) {
                label = button.dataset.lightboxLabel || 'Employee photo';
            }

            return {
                key: getImageKey(image),
                src,
                label
            };
        }).filter(Boolean);

        safeWriteJsonToLocalStorage(IMAGE_GALLERY_CACHE_KEY, {
            updatedAt: new Date().toISOString(),
            count: gallerySnapshot.length,
            items: gallerySnapshot
        });

        if (lightbox) {
            lightbox.addEventListener('click', (event) => {
                if (event.target === lightbox) {
                    closeLightbox();
                }
            });
        }

        if (lightboxImage) {
            lightboxImage.addEventListener('click', (event) => {
                event.stopPropagation();
            });
        }

        if (lightboxClose) {
            lightboxClose.addEventListener('click', (event) => {
                event.preventDefault();
                event.stopPropagation();
                closeLightbox();
            });
        }
    });
</script>
