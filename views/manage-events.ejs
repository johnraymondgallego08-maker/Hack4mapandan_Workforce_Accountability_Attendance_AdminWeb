<div class="page-container" style="max-width: 1100px; margin: 0 auto;">
    <div class="page-header" style="margin-bottom: 1.25rem; display:flex; justify-content:space-between; align-items:center;">
        <div>
            <h1>Manage Events & Announcements</h1>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Create, edit, publish, or remove events and announcements. New records are saved to Firebase Firestore.</p>
        </div>
    </div>

    <div class="events-grid">
        <div class="card" style="padding: 1rem;">
            <h3 style="margin-top:0; margin-bottom:0.75rem;">Create New</h3>
            <form action="/manage-events/create" method="POST" enctype="multipart/form-data" onsubmit="confirmCreate(this, 'Create Post', 'Publish this new event or announcement?')">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:0.5rem; margin-bottom:0.5rem;">
                    <div>
                        <label for="type" style="display:block; font-weight:700; margin-bottom:0.25rem;">Type</label>
                        <select id="type" name="type" required>
                            <option value="announcement">Announcement</option>
                            <option value="event">Event</option>
                        </select>
                    </div>
                    <div>
                        <label for="status" style="display:block; font-weight:700; margin-bottom:0.25rem;">Status</label>
                        <select id="status" name="status" required>
                            <option value="Public">Public</option>
                            <option value="Draft">Draft</option>
                        </select>
                    </div>
                </div>

                <label for="title" style="display:block; font-weight:700; margin-bottom:0.25rem;">Title</label>
                <input type="text" id="title" name="title" required style="margin-bottom:0.5rem;">

                <label for="summary" style="display:block; font-weight:700; margin-bottom:0.25rem;">Summary</label>
                <textarea id="summary" name="summary" rows="3" style="margin-bottom:0.5rem;"></textarea>

                <label for="content" style="display:block; font-weight:700; margin-bottom:0.25rem;">Content</label>
                <textarea id="content" name="content" rows="5" style="margin-bottom:0.5rem;"></textarea>

                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:0.5rem; margin-bottom:0.5rem;">
                    <div>
                        <label for="eventDate" style="display:block; font-weight:700; margin-bottom:0.25rem;">Date</label>
                        <input type="date" id="eventDate" name="eventDate">
                    </div>
                    <div>
                        <label for="eventTime" style="display:block; font-weight:700; margin-bottom:0.25rem;">Time</label>
                        <input type="time" id="eventTime" name="eventTime">
                    </div>
                </div>

                <label for="location" style="display:block; font-weight:700; margin-bottom:0.25rem;">Location</label>
                <input type="text" id="location" name="location" style="margin-bottom:0.5rem;">

                <label for="coverImage" style="display:block; font-weight:700; margin-bottom:0.25rem;">Cover Photo</label>
                <input type="file" id="coverImage" name="coverImage" accept="image/*" onchange="previewCover(this, 'coverPreview')" style="margin-bottom:0.5rem;">

                <div id="coverPreview" style="width:100%; max-width:320px; height:160px; border-radius:8px; overflow:hidden; margin-bottom:0.5rem; display:none; border:1px solid var(--border-glass); background: rgba(0,0,0,0.02);">
                    <img src="" alt="Cover preview" style="width:100%; height:100%; object-fit:cover; display:block;">
                </div>

                <div style="display:flex; gap:0.5rem; margin-top:0.5rem;">
                    <button type="submit" class="btn btn-primary" style="flex:1;">Create</button>
                    <button type="reset" class="btn" style="flex:1;" onclick="document.getElementById('coverPreview').style.display='none'">Reset</button>
                </div>
            </form>
        </div>

        <div class="card" style="padding:1rem;">
            <h3 style="margin-top:0; margin-bottom:0.75rem;">Published Records</h3>

            <% if (!Array.isArray(records) || records.length === 0) { %>
                <p style="color:var(--text-muted);">No events or announcements yet.</p>
            <% } else { %>
                <div class="table-responsive">
                <table style="width:100%; border-collapse:collapse;">
                    <thead>
                        <tr>
                            <th style="text-align:left; padding:0.5rem;">Title</th>
                            <th style="padding:0.5rem;">Type</th>
                            <th style="padding:0.5rem;">Schedule</th>
                            <th style="padding:0.5rem;">Status</th>
                            <th style="padding:0.5rem;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% records.forEach(function(record) { %>
                            <tr>
                                <td style="padding:0.5rem; vertical-align:middle;"><strong><%= record.title %></strong><br><small style="color:var(--text-muted);"><%= record.summary ? (record.summary.length > 80 ? (record.summary.substring(0,77)+'...') : record.summary) : '' %></small></td>
                                <td style="padding:0.5rem; text-align:center;"><%= record.type %></td>
                                <td style="padding:0.5rem; text-align:center;"><%= record.scheduleLabel || '—' %></td>
                                <td style="padding:0.5rem; text-align:center;"><%= record.status %></td>
                                <td style="padding:0.5rem; text-align:center;">
                                    <div style="display:flex; gap:0.35rem; flex-wrap:nowrap; justify-content:center; align-items:center; overflow-x:auto; -webkit-overflow-scrolling:touch; white-space:nowrap;">
                                        <a href="/manage-events/edit/<%= record.id %>" class="btn-action" title="Edit" aria-label="Edit" style="margin:0;">
                                            <i data-lucide="edit"></i>
                                        </a>

                                        <form action="/manage-events/delete/<%= record.id %>" method="POST" style="display:inline-block; margin:0;" onsubmit="confirmDelete(this, 'Delete record', 'This will permanently remove the record.')">
                                            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                            <button type="submit" class="btn-action btn-delete" title="Delete" aria-label="Delete" style="margin:0;">
                                                <i data-lucide="trash-2"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof lucide !== 'undefined' && lucide.createIcons) lucide.createIcons();
    });

    function previewCover(input, previewId) {
        const previewContainer = document.getElementById(previewId);
        if (!previewContainer) return;
        const img = previewContainer.querySelector('img');
        const file = input.files && input.files[0];
        if (!file) {
            previewContainer.style.display = 'none';
            img.src = '';
            return;
        }

        const reader = new FileReader();
        reader.onload = function(e) {
            img.src = e.target.result;
            previewContainer.style.display = 'block';
        };
        reader.readAsDataURL(file);
    }

    function confirmCreate(form, title = 'Create', text = 'Create this record?') {
        if (event) event.preventDefault();
        if (typeof Swal === 'undefined') return form.submit();
        Swal.fire({
            ...buildSwalOptions({ title, text, icon: 'question', confirmButtonText: 'Create', accent: 'primary' })
        }).then((result) => {
            if (result.isConfirmed) form.submit();
        });
    }
</script>
