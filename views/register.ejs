<div class="page-container" style="max-width: 600px; margin: 0 auto;">
    <div class="page-header" style="margin-bottom: 2rem; text-align: center;">
        <div>
            <h1>Add New Employee</h1>
            <p style="color: var(--text-muted); font-size: 0.9rem;">Create a new system user and set their initial credentials.</p>
        </div>
    </div>

    <div class="card" style="padding: 2.5rem;">
        <form action="/register" method="POST">
            <div style="margin-bottom: 1.5rem;">
                <label for="name" style="display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.5rem;">Full Name</label>
                <div style="position: relative;">
                    <i data-lucide="user" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: var(--text-muted);"></i>
                    <input type="text" id="name" name="name" placeholder="e.g. John Doe" required style="width: 100%; padding-left: 3rem;">
                </div>
            </div>
            <div style="margin-bottom: 1.5rem;">
                <label for="email" style="display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.5rem;">Email Address</label>
                <div style="position: relative;">
                    <i data-lucide="mail" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: var(--text-muted);"></i>
                    <input type="email" id="email" name="email" placeholder="john@example.com" required style="width: 100%; padding-left: 3rem;">
                </div>
            </div>
            <div style="margin-bottom: 1.5rem;">
                <label for="password" style="display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.5rem;">Initial Password</label>
                <div style="position: relative;">
                    <i data-lucide="lock" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: var(--text-muted);"></i>
                    <input type="password" id="password" name="password" placeholder="••••••••" required style="width: 100%; padding-left: 3rem;">
                </div>
            </div>
            <div style="margin-bottom: 2rem;">
                <label for="role" style="display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.5rem;">Access Level</label>
                <div style="position: relative;">
                    <i data-lucide="shield" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: var(--text-muted);"></i>
                    <select id="role" name="role" required style="width: 100%; padding-left: 3rem;">
                        <option value="Employee">Employee</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                <div>
                    <label for="department" style="display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.5rem;">Department</label>
                    <input type="text" id="department" name="department" placeholder="IT, HR, Finance..." style="width: 100%;">
                </div>
                <div>
                    <label for="position" style="display: block; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.5rem;">Position</label>
                    <input type="text" id="position" name="position" placeholder="Manager, Developer..." style="width: 100%;">
                </div>
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; font-weight: 800; letter-spacing: 0.05em; display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                <i data-lucide="user-plus" style="width: 18px; height: 18px;"></i>
                <span>CREATE SYSTEM USER</span>
            </button>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        lucide.createIcons();
    });
</script>
