<div class="page-container">
    <style>
        /* Optimize History Table for compact visibility */
        #historyTable {
            width: 100%;
        }

        #historyTable th,
        #historyTable td {
            padding: 0.7rem 0.85rem !important;
            font-size: 0.85rem;
            vertical-align: top;
        }

        #historyTable th:last-child,
        #historyTable td:last-child {
            padding-right: 1.5rem !important;
        }

        #historyTable th:nth-child(1),
        #historyTable td:nth-child(1) {
            min-width: 220px;
        }

        #historyTable th:nth-child(2),
        #historyTable td:nth-child(2) {
            min-width: 140px;
        }

        #historyTable th:nth-child(6),
        #historyTable td:nth-child(6) {
            min-width: 300px;
        }

        #historyTable th:nth-child(3),
        #historyTable td:nth-child(3),
        #historyTable th:nth-child(4),
        #historyTable td:nth-child(4),
        #historyTable th:nth-child(5),
        #historyTable td:nth-child(5),
        #historyTable th:nth-child(7),
        #historyTable td:nth-child(7),
        #historyTable th:nth-child(8),
        #historyTable td:nth-child(8),
        #historyTable th:nth-child(9),
        #historyTable td:nth-child(9) {
            white-space: nowrap;
        }

        /* Sticky Header and Action Column Fix for Request History */
        #historyTable {
            border-collapse: separate;
            border-spacing: 0;
        }

        #historyTable thead th {
            position: sticky;
            top: 0;
            z-index: 20;
            background: #ffffff;
        }

        #historyTable th:last-child,
        #historyTable td:last-child {
            position: sticky;
            right: 0;
            z-index: 10;
            background: #ffffff;
        }

        #historyTable thead th:last-child {
            z-index: 30;
        }
    </style>
    <div class="page-header">
        <div>
            <h1>Manage Leave Requests</h1>
            <!-- <p style="color: var(--text-muted); font-size: 0.9rem;">Review pending leave applications and maintain the request history.</p> -->
        </div>
    </div>

    <% const pendingLeaves=[]; const historyLeaves=[]; if (locals.leaves) { leaves.forEach(leave=> {
        if (!leave.status || leave.status.toLowerCase() === 'pending') {
        pendingLeaves.push(leave);
        } else {
        historyLeaves.push(leave);
        }
        });
        }
        %>

        <!-- Pending Requests Section -->
        <div class="card" style="padding: 0; overflow: hidden; border-radius: 1.5rem; margin-bottom: 2rem;">
            <div class="card-header" style="padding: 1.5rem 2rem; display: flex; flex-direction: column; gap: 1.25rem; background: #fff; border-bottom: 1px solid #f3f4f6;">
                <h3>Pending Applications</h3>
                <div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 1rem; width: 100%;">
                    <div class="search-wrapper" style="position: relative;">
                        <i data-lucide="search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 18px; color: #9ca3af;"></i>
                        <input type="text" id="pendingSearchInput" placeholder="Search pending names or reasons..." style="width: 100%; padding: 0.75rem 0.75rem 0.75rem 2.75rem; border: 1.5px solid #e5e7eb; border-radius: 10px; font-size: 0.9rem;">
                    </div>
                    <select id="pendingEmployeeFilter" style="padding: 0.75rem; border: 1.5px solid #e5e7eb; border-radius: 10px; background: #f9fafb; font-weight: 500; color: #374151;">
                        <option value="">All Employees</option>
                        <% const pEmps = [...new Set(pendingLeaves.map(l => l.employeeName))].sort(); %>
                        <% pEmps.forEach(emp => { %>
                            <option value="<%= emp %>"><%= emp %></option>
                        <% }) %>
                    </select>
                    <select id="pendingTypeFilter" style="padding: 0.75rem; border: 1.5px solid #e5e7eb; border-radius: 10px; background: #f9fafb; font-weight: 500; color: #374151;">
                        <option value="">All Types</option>
                        <% const pTypes = [...new Set(pendingLeaves.map(l => l.leaveType || l.type))].sort(); %>
                        <% pTypes.forEach(type => { %>
                            <option value="<%= type %>"><%= type %></option>
                        <% }) %>
                    </select>
                </div>
            </div>
            <div class="table-responsive" style="margin-top: 0; border: none; border-radius: 0; --table-min-width: 1180px;">
                <table id="pendingLeavesTable">
                    <thead>
                        <tr>
                            <th style="white-space: nowrap;">Employee</th>
                            <th style="white-space: nowrap;">Type</th>
                            <th style="white-space: nowrap; text-align: right;" data-sortable="true">Requested On</th>
                            <th style="white-space: nowrap; text-align: right;" data-sortable="true">
                                Start Date</th>
                            <th style="white-space: nowrap; text-align: right;" data-sortable="true">
                                End Date</th>
                            <th style="min-width: 200px;">Reason</th>
                            <th style="text-align: right;">Status</th>
                            <th style="text-align: right; min-width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (pendingLeaves.length> 0) { %>
                            <% pendingLeaves.forEach(leave=> { %>
                                <tr>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: 0.75rem;">
                                            <div
                                                style="width: 32px; height: 32px; border-radius: 50%; background: var(--primary-gradient); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 800; overflow: hidden; flex-shrink: 0;">
                                                <% if (leave.photoUrl) { %>
                                                    <img src="<%= leave.photoUrl %>" alt="<%= leave.employeeName %>"
                                                        style="width: 100%; height: 100%; object-fit: cover;">
                                                    <% } else { %>
                                                        <%= leave.employeeName.charAt(0).toUpperCase() %>
                                                            <% } %>
                                            </div>
                                            <span style="font-weight: 700; color: var(--text-heading);">
                                                <%= leave.employeeName %>
                                            </span>
                                        </div>
                                    </td>
                                    <td style="font-weight: 600; color: var(--text-muted);">
                                        <%= leave.leaveType || leave.type %>
                                    </td>
                                    <td
                                        style="white-space: nowrap; color: var(--text-muted); font-size: 0.85rem; text-align: right;">
                                        <%= leave.requestedDate || leave.actionDate || leave.startDate || '-' %>
                                    </td>
                                    <td
                                        style="white-space: nowrap; color: var(--text-muted); font-size: 0.85rem; text-align: right;">
                                        <%= leave.startDate %>
                                    </td>
                                    <td
                                        style="white-space: nowrap; color: var(--text-muted); font-size: 0.85rem; text-align: right;">
                                        <%= leave.endDate %>
                                    </td>
                                    <td
                                        style="font-size: 0.85rem; color: var(--text-muted); max-width: 320px; white-space: normal; word-break: break-word; overflow-wrap: anywhere; line-height: 1.5;">
                                        <%= leave.reason %>
                                    </td>
                                    <td style="text-align: right;">
                                        <span class="status-badge status-late">Pending</span>
                                    </td>
                                    <td style="text-align: right;">
                                        <div class="table-action-group">
                                            <form action="/leave/approve/<%= leave.id %>" method="POST" class="inline">
                                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                                <button type="submit" class="btn-action btn-approve" title="Approve">
                                                    <i data-lucide="check" style="width: 18px; height: 18px;"></i>
                                                </button>
                                            </form>
                                            <form action="/leave/reject/<%= leave.id %>" method="POST" class="inline">
                                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                                <button type="submit" class="btn-action btn-reject" title="Reject">
                                                    <i data-lucide="x" style="width: 18px; height: 18px;"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="8"
                                                style="padding: 3rem; text-align: center; color: var(--text-muted); font-style: italic;">
                                                No pending requests.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- History Section -->
        <div class="card" style="padding: 0; overflow: hidden; border-radius: 1.5rem;">
            <div class="card-header" style="padding: 1.5rem 2rem; display: flex; flex-direction: column; gap: 1.25rem; background: #fff; border-bottom: 1px solid #f3f4f6;">
                <div>
                    <h3 style="margin: 0;">Request History</h3>
                </div>
                <div style="display: flex; flex-wrap: wrap; gap: 1rem; width: 100%; align-items: center;">
                    <div class="search-wrapper" style="position: relative; flex: 2 1 250px; min-width: 0;">
                        <i data-lucide="search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 18px; color: #9ca3af;"></i>
                        <input type="text" id="historySearchInput" placeholder="Search history..." style="width: 100%; height: 2.75rem; padding: 0 0.75rem 0 2.75rem; border: 1.5px solid #e5e7eb; border-radius: 10px; font-size: 0.9rem; box-sizing: border-box;">
                    </div>
                    <select id="historyEmployeeFilter" style="flex: 1 1 150px; min-width: 0; height: 2.75rem; padding: 0 0.75rem; border: 1.5px solid #e5e7eb; border-radius: 10px; background: #f9fafb; font-weight: 500; color: #374151; font-size: 0.9rem; box-sizing: border-box;">
                        <option value="">All Employees</option>
                        <% const hEmps = [...new Set(historyLeaves.map(l => l.employeeName))].sort(); %>
                        <% hEmps.forEach(emp => { %>
                            <option value="<%= emp %>"><%= emp %></option>
                        <% }) %>
                    </select>
                    <select id="historyTypeFilter" style="flex: 1 1 150px; min-width: 0; height: 2.75rem; padding: 0 0.75rem; border: 1.5px solid #e5e7eb; border-radius: 10px; background: #f9fafb; font-weight: 500; color: #374151; font-size: 0.9rem; box-sizing: border-box;">
                        <option value="">All Types</option>
                        <% const hTypes = [...new Set(historyLeaves.map(l => l.leaveType || l.type))].sort(); %>
                        <% hTypes.forEach(type => { %>
                            <option value="<%= type %>"><%= type %></option>
                        <% }) %>
                    </select>
                    <select id="statusFilter" style="flex: 1 1 150px; min-width: 0; height: 2.75rem; padding: 0 0.75rem; border: 1.5px solid #e5e7eb; border-radius: 10px; background: #f9fafb; font-weight: 500; color: #374151; font-size: 0.9rem; box-sizing: border-box;">
                        <option value="">All Status</option>
                        <option value="approved">Approved</option>
                        <option value="rejected">Rejected</option>
                    </select>
                    <button type="button" id="exportHistoryCSV" style="flex: 0 0 auto; background: #dc2626; color: white; border: 1.5px solid transparent; height: 2.75rem; padding: 0 1.25rem; margin-bottom: 1rem; border-radius: 10px; font-size: 0.9rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem; cursor: pointer; transition: all 0.2s; white-space: nowrap; box-sizing: border-box;" onmouseover="this.style.opacity='0.9'; this.style.transform='translateY(-1px)'" onmouseout="this.style.opacity='1'; this.style.transform='translateY(0)'">
                        <i data-lucide="download" style="width: 18px; height: 18px;"></i>
                        Export CSV
                    </button>
                </div>
            </div>
            <div class="table-responsive"
                style="margin-top: 0; border: none; border-radius: 0; --table-min-width: 1320px;">
                <table id="historyTable">
                    <thead>
                        <tr>
                            <th data-sortable="true">Employee</th>
                            <th data-sortable="true">Type</th>
                            <th style="text-align: right; white-space: nowrap;" data-sortable="true">Requested On</th>
                            <th style="text-align: right;" data-sortable="true">Start Date</th>
                            <th style="text-align: right;" data-sortable="true">End Date</th>
                            <th>Reason</th>
                            <th style="text-align: right; white-space: nowrap;" data-sortable="true">Action Date</th>
                            <th style="text-align: right;" data-sortable="true">Status</th>
                            <th style="text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="historyTableBody">
                        <% if (historyLeaves.length> 0) { %>
                            <% historyLeaves.forEach(leave=> { %>
                                <tr>
                                    <td>
                                        <div style="display: flex; align-items: center; gap: 0.75rem;">
                                            <div
                                                style="width: 28px; height: 28px; border-radius: 50%; background: var(--primary-gradient); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 800; overflow: hidden; flex-shrink: 0;">
                                                <% if (leave.photoUrl) { %>
                                                    <img src="<%= leave.photoUrl %>" alt="<%= leave.employeeName %>"
                                                        style="width: 100%; height: 100%; object-fit: cover;">
                                                    <% } else { %>
                                                        <%= leave.employeeName.charAt(0).toUpperCase() %>
                                                            <% } %>
                                            </div>
                                            <span style="font-weight: 700; color: var(--text-heading);">
                                                <%= leave.employeeName %>
                                            </span>
                                        </div>
                                    </td>
                                    <td style="font-weight: 600; color: var(--text-muted);">
                                        <%= leave.leaveType || leave.type %>
                                    </td>
                                    <td
                                        style="text-align: right; font-size: 0.75rem; color: var(--text-muted); font-family: monospace; white-space: nowrap;">
                                        <%= leave.requestedDate || leave.actionDate || leave.startDate || '-' %>
                                    </td>
                                    <td
                                        style="white-space: nowrap; color: var(--text-muted); font-size: 0.85rem; text-align: right;">
                                        <%= leave.startDate %>
                                    </td>
                                    <td
                                        style="white-space: nowrap; color: var(--text-muted); font-size: 0.85rem; text-align: right;">
                                        <%= leave.endDate %>
                                    </td>
                                    <td
                                        style="font-size: 0.85rem; color: var(--text-muted); max-width: 320px; white-space: normal; word-break: break-word; overflow-wrap: anywhere; line-height: 1.5;">
                                        <%= leave.reason %>
                                    </td>
                                    <td
                                        style="text-align: right; font-size: 0.75rem; color: var(--text-muted); font-family: monospace;">
                                        <%= leave.actionDate || '-' %>
                                    </td>
                                    <td style="text-align: right;">
                                        <% let statusClass='status-default' ; const stat=(leave.status || ''
                                            ).toLowerCase(); if(stat==='approved' ) statusClass='status-present' ;
                                            if(stat==='rejected' ) statusClass='status-absent' ; %>
                                            <span class="status-badge <%= statusClass %>">
                                                <%= leave.status %>
                                            </span>
                                    </td>
                                    <td style="text-align: right;">
                                        <div class="table-action-group">
                                            <form action="/leave/delete/<%= leave.id %>" method="POST" class="inline"
                                                onsubmit="confirmDelete(this, 'Delete Leave Record', 'This will permanently remove this leave request from history.')">
                                                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                                <button type="submit" class="btn-action btn-delete" title="Delete">
                                                    <i data-lucide="trash-2" style="width: 18px; height: 18px;"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr data-empty-state="true">
                                            <td colspan="9"
                                                style="padding: 3rem; text-align: center; color: var(--text-muted); font-style: italic;">
                                                No history found.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
            <div class="pagination-controls"
                style="padding: 1.5rem; display: flex; justify-content: center; gap: 0.5rem; background: rgba(255,255,255,0.02);">
            </div>
        </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        lucide.createIcons();

        // Generic Filtering Function
        function applyTableFilters(tableId, searchInputId, empFilterId, typeFilterId, statusFilterId = null) {
            const searchTerm = document.getElementById(searchInputId).value.toLowerCase();
            const selectedEmp = document.getElementById(empFilterId).value;
            const selectedType = document.getElementById(typeFilterId).value;
            const selectedStatus = statusFilterId ? document.getElementById(statusFilterId).value.toLowerCase() : null;
            
            const rows = document.querySelectorAll(`#${tableId} tbody tr`);

            rows.forEach(row => {
                if (row.hasAttribute('data-empty-state') || row.cells.length < 5) return;

                const empName = row.cells[0].textContent.trim();
                const leaveType = row.cells[1].textContent.trim();
                const reason = row.cells[5].textContent.trim().toLowerCase();
                const status = statusFilterId ? row.cells[7].textContent.trim().toLowerCase() : null;

                const matchesSearch = empName.toLowerCase().includes(searchTerm) || reason.includes(searchTerm);
                const matchesEmp = !selectedEmp || empName === selectedEmp;
                const matchesType = !selectedType || leaveType === selectedType;
                const matchesStatus = !selectedStatus || status === selectedStatus;

                const isVisible = matchesSearch && matchesEmp && matchesType && matchesStatus;
                row.setAttribute('data-filtered', isVisible ? 'false' : 'true');
                row.style.display = isVisible ? '' : 'none';
            });

            if (window.tableManagers && window.tableManagers[tableId]) {
                window.tableManagers[tableId].reinitialize();
            }
        }

        // CSV Export Functionality for Request History
        function exportTableToCSV(tableId, filename) {
            const table = document.getElementById(tableId);
            if (!table) return;
            
            const rows = Array.from(table.querySelectorAll('tr'));
            const csvContent = rows
                .filter(row => row.getAttribute('data-filtered') !== 'true' && !row.hasAttribute('data-empty-state'))
                .map(row => {
                    const cells = Array.from(row.querySelectorAll('th, td'));
                    // Exclude the 'Actions' column (last column index 8)
                    return cells.slice(0, -1).map(cell => {
                        let text = cell.innerText.replace(/(\r\n|\n|\r)/gm, " ").replace(/\s+/g, ' ').trim();
                        // Escape double quotes by doubling them
                        text = text.replace(/"/g, '""');
                        return `"${text}"`;
                    }).join(',');
                })
                .filter(rowStr => rowStr.trim().length > 0)
                .join('\n');

            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement("a");
            if (link.download !== undefined) {
                const url = URL.createObjectURL(blob);
                link.setAttribute("href", url);
                link.setAttribute("download", filename);
                link.style.visibility = 'hidden';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            }
        }

        document.getElementById('exportHistoryCSV').addEventListener('click', () => {
            exportTableToCSV('historyTable', `leave-history-${new Date().toISOString().split('T')[0]}.csv`);
        });

        // Pending Listeners
        const pendingInputs = ['pendingSearchInput', 'pendingEmployeeFilter', 'pendingTypeFilter'];
        pendingInputs.forEach(id => {
            document.getElementById(id).addEventListener('input', () => {
                applyTableFilters('pendingLeavesTable', 'pendingSearchInput', 'pendingEmployeeFilter', 'pendingTypeFilter');
            });
        });

        // History Listeners
        const historyInputs = ['historySearchInput', 'historyEmployeeFilter', 'historyTypeFilter', 'statusFilter'];
        historyInputs.forEach(id => {
            document.getElementById(id).addEventListener('input', () => {
                applyTableFilters('historyTable', 'historySearchInput', 'historyEmployeeFilter', 'historyTypeFilter', 'statusFilter');
            });
        });

        // Existing table management for pagination/etc
        if (typeof initTableManagement === 'function') {
            initTableManagement('#historyTable', '#historySearchInput', '.pagination-controls', 8, {
                statusFilterSelector: '#statusFilter'
            });
        }
    });
</script>
<script src="/js/leave-realtime.js"></script>
