<style>
    .monitor-grid {
        display: grid; 
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
        gap: 1.5rem;
    }
    .user-card {
        padding: 0; 
        display: flex; 
        flex-direction: column; 
        overflow: hidden; 
        transition: transform 0.3s ease, box-shadow 0.3s ease; 
        height: 100%;
    }
    .user-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }
    .avatar-circle {
        width: 48px; 
        height: 48px; 
        border-radius: 50%; 
        background: var(--primary-gradient); 
        color: white; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        font-size: 1.25rem; 
        font-weight: 800; 
        box-shadow: var(--shadow-glow);
    }
    .card-content {
        padding: 1.5rem; 
        flex-grow: 1;
    }
    .view-btn {
        width: 100%; 
        padding: 1rem; 
        font-size: 0.75rem; 
        font-weight: 800; 
        letter-spacing: 0.1em; 
        background: rgba(255,255,255,0.03); 
        color: var(--text-muted); 
        border-top: 1px solid var(--border-glass); 
        text-transform: uppercase; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        gap: 0.5rem; 
        border-radius: 0; 
        box-shadow: none;
    }
</style>

<div class="page-container">
    <div class="page-header">
        <div>
            <h1>Real-Time Workforce Monitoring</h1>
            <p class="text-muted" style="font-size: 0.9rem;"></p>
        </div>
        <div class="search-wrapper">
            <i data-lucide="search"></i>
            <input type="text" id="monitorSearch" placeholder="Find Employee...">
        </div>
    </div>

    <div id="monitorGrid" class="monitor-grid">
        <% if (locals.users && users.length > 0) { %>
            <% users.forEach(user => { %>
                <div class="user-card card">
                    <div class="card-content">
                        <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1.5rem;">
                            <div class="avatar-circle">
                                <%= user.name ? user.name.charAt(0).toUpperCase() : '?' %>
                            </div>
                            <span class="status-badge <%= user.status && user.status.toLowerCase() === 'active' ? 'status-present' : 'status-default' %>">
                                <%= user.status || 'Unknown' %>
                            </span>
                        </div>
                        <h3 class="user-name" style="font-size: 1.15rem; font-weight: 800; color: var(--text-heading); margin-bottom: 0.25rem;">
                            <%= user.name || 'Unnamed User' %>
                        </h3>
                        <p class="user-role" style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted);">
                            <%= user.role || 'Personnel' %>
                        </p>
                    </div>
                    <a href="/attendance-monitor?employeeId=<%= encodeURIComponent(String(user.id || '')) %>&search=<%= encodeURIComponent(user.name || '') %>" class="btn view-btn">
                        <i data-lucide="activity" style="width: 14px; height: 14px;"></i>
                        <span>View Attendance Details</span>
                    </a>
                </div>
            <% }) %>
        <% } else { %>
            <div style="grid-column: 1 / -1; padding: 4rem; text-align: center; background: var(--surface-glass); border: 2px dashed var(--border-glass); border-radius: 1rem;">
                <p style="color: var(--text-muted); font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">No workforce members available to monitor.</p>
            </div>
        <% } %>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        lucide.createIcons();

        const searchInput = document.getElementById('monitorSearch');
        const userCards = document.querySelectorAll('.user-card');

        if (searchInput) {
            searchInput.addEventListener('input', (e) => {
                const term = e.target.value.toLowerCase().trim();
                userCards.forEach(card => {
                    const name = card.querySelector('.user-name').textContent.toLowerCase();
                    const role = card.querySelector('.user-role').textContent.toLowerCase();
                    const matches = name.includes(term) || role.includes(term);
                    card.style.display = matches ? 'flex' : 'none';
                });
            });
        }
    });
</script>
