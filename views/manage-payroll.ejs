<div class="page-container">
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
        <div>
            <h1>Manage Payroll</h1>
            <p style="color: var(--text-muted); font-size: 0.9rem;"></p>
        </div>
        <div class="payroll-filters" style="background: rgba(255,255,255,0.03); padding: 0.75rem 1.25rem; border-radius: 1rem; border: 1px solid var(--border-glass);">
            <form action="/manage-payroll" method="GET" class="form-compact" style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                    <i data-lucide="calendar" style="width: 18px; height: 18px; color: var(--accent-primary);"></i>
                    <select name="month" onchange="this.form.submit()" class="btn" style="background: transparent; color: var(--text-heading); border: none; padding: 0.25rem; cursor: pointer; font-weight: 600; outline: none; min-width: 120px;">
                        <% const months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']; %>
                        <% months.forEach((monthName, index) => { %>
                            <option value="<%= index %>" <%= selectedMonth === index ? 'selected' : '' %>><%= monthName %></option>
                        <% }) %>
                    </select>
                </div>
                <div style="width: 1px; height: 20px; background: var(--border-glass);"></div>
                <select name="year" onchange="this.form.submit()" class="btn" style="background: transparent; color: var(--text-heading); border: none; padding: 0.25rem; cursor: pointer; font-weight: 600; outline: none;">
                    <% const startYear = 2024; const endYear = 2028; for (let yr = startYear; yr <= endYear; yr += 1) { %>
                        <option value="<%= yr %>" <%= selectedYear === yr ? 'selected' : '' %>><%= yr %></option>
                    <% } %>
                </select>
            </form>
        </div>
    </div>

    <div class="card" style="padding: 0; overflow: hidden; border-radius: 1.5rem;">
        <div class="card-header">
            <h3>Payroll Overview</h3>
            <div class="search-wrapper">
                <i data-lucide="search"></i>
                <input type="text" id="searchInput" placeholder="Find Payroll Records...">
            </div>
        </div>

        <div class="table-responsive" style="margin-top: 0; border: none; border-radius: 0; --table-min-width: 1400px;">
            <table id="payrollTable">
                <thead>
                    <tr>
                        <th data-sortable="true">Employee</th>
                        <th data-sortable="true">Date</th>
                        <th data-sortable="true">Period</th>
                        <th data-sortable="true" style="text-align: right;">Total Salary</th>
                        <th style="text-align: right;">Daily Computation</th>
                        <th style="text-align: right;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (locals.payroll && payroll.length > 0) { %>
                        <% payroll.forEach((p) => { %>
                            <% const defaultPayDate = p.selectedPayDate === 'end' ? 'end' : '15'; %>
                            <% const payrollSlots = [
                                { key: '15', label: (p.midRecord && p.midRecord.paymentDate) ? p.midRecord.paymentDate : '15th', record: p.midRecord || null },
                                { key: 'end', label: (p.endRecord && p.endRecord.paymentDate) ? p.endRecord.paymentDate : 'End of Month', record: p.endRecord || null }
                            ]; %>
                            <tr class="payroll-employee-row" data-default-pay-date="<%= defaultPayDate %>">
                                <td>
                                    <div style="font-weight: 700; color: var(--text-heading); white-space: nowrap;"><%= p.employeeName %></div>
                                    <div style="font-size: 0.75rem; color: var(--text-muted);"><%= p.employeeCode || p.employeeId || 'No employee code' %></div>
                                </td>
                                <td style="color: var(--text-muted); font-size: 0.85rem;">
                                    <select class="payroll-row-date-select btn" style="background: rgba(255,255,255,0.72); color: var(--text-heading); border: 1px solid var(--border-glass); padding: 0.4rem 0.65rem; cursor: pointer; font-weight: 700; outline: none; min-width: 165px;">
                                        <% payrollSlots.forEach((slot) => { %>
                                            <option value="<%= slot.key %>" <%= defaultPayDate === slot.key ? 'selected' : '' %>><%= slot.label %></option>
                                        <% }) %>
                                    </select>
                                </td>
                                <td style="color: var(--accent-primary); font-size: 0.85rem; font-weight: 600;">
                                    <% payrollSlots.forEach((slot) => { const record = slot.record || {}; %>
                                        <div class="payroll-slot" data-payroll-slot="period" data-pay-date="<%= slot.key %>" style="<%= defaultPayDate === slot.key ? '' : 'display:none;' %>">
                                            <%= record.period || 'N/A' %>
                                        </div>
                                    <% }) %>
                                </td>
                                <td class="text-right">
                                    <% payrollSlots.forEach((slot) => { const record = slot.record || {}; const displayNetPay = Number(record.displayNetPay !== undefined ? record.displayNetPay : record.netPay || 0); %>
                                        <div class="payroll-slot" data-payroll-slot="salary" data-pay-date="<%= slot.key %>" style="<%= defaultPayDate === slot.key ? '' : 'display:none;' %>">
                                            <div class="font-mono payroll-money-chip">
                                                <span style="padding: 0 0.5rem;">&#8369;<%= displayNetPay.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
                                            </div>
                                        </div>
                                    <% }) %>
                                </td>
                                <td style="text-align: right;">
                                    <% payrollSlots.forEach((slot) => { const record = slot.record || {}; const salaryAmount = Number(record.basic !== undefined && record.basic !== null ? record.basic : (record.salary || 0)) || 0; const bonusPay = Number(record.bonus || 0) || 0; const deductionPay = Number(record.deductions || 0) || 0; const netPayAmount = Number(record.displayNetPay !== undefined ? record.displayNetPay : record.netPay) || 0; const dailyHistory = Array.isArray(record.dailyHistory) ? record.dailyHistory : []; const totalDays = dailyHistory.length; const totalHours = dailyHistory.reduce((sum, day) => sum + (Number(day.hours) || 0), 0); const totalDailyAmount = dailyHistory.reduce((sum, day) => sum + (Number(day.amount) || 0), 0); const calcPanelId = `history-${String(p.employeeId || 'employee').replace(/[^a-zA-Z0-9_-]/g, '-')}-${slot.key}`; %>
                                        <div class="payroll-slot" data-payroll-slot="calculation" data-pay-date="<%= slot.key %>" style="<%= defaultPayDate === slot.key ? '' : 'display:none;' %>">
                                            <div class="payroll-calc-wrap">
                                                <button type="button" class="payroll-calc-toggle" data-target="<%= calcPanelId %>" aria-expanded="false">
                                                    <span>Daily Computation</span>
                                                    <i data-lucide="chevron-down" class="payroll-calc-chevron"></i>
                                                </button>
                                                <div id="<%= calcPanelId %>" class="payroll-calc-panel">
                                                    <% if (dailyHistory.length > 0) { %>
                                                        <div class="payroll-calc-summary">
                                                            <span class="payroll-calc-chip">Days: <strong><%= totalDays %></strong></span>
                                                            <span class="payroll-calc-chip">Hours: <strong><%= totalHours.toFixed(2) %></strong></span>
                                                            <span class="payroll-calc-chip">Salary: <strong>&#8369;<%= totalDailyAmount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></strong></span>
                                                            <span class="payroll-calc-chip">Bonus: <strong>&#8369;<%= bonusPay.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></strong></span>
                                                            <span class="payroll-calc-chip">Deductions: <strong>&#8369;<%= deductionPay.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></strong></span>
                                                            <span class="payroll-calc-chip">Total: <strong>&#8369;<%= netPayAmount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></strong></span>
                                                        </div>

                                                        <div class="payroll-calc-table">
                                                            <div class="payroll-calc-row payroll-calc-head">
                                                                <span>Date</span>
                                                                <span>Work Log</span>
                                                                <span>Daily Salary</span>
                                                            </div>
                                                            <% dailyHistory.forEach((day) => { %>
                                                                <div class="payroll-calc-row">
                                                                    <span><%= day.date %></span>
                                                                    <span><%= Number(day.hours) > 0 ? `${Number(day.hours).toFixed(2)}h worked` : 'Login recorded' %></span>
                                                                    <span>&#8369;<%= Number(day.amount).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
                                                                </div>
                                                            <% }) %>
                                                            <div class="payroll-calc-row payroll-calc-total-row">
                                                                <span>Base Salary</span>
                                                                <span><%= totalDays %> day(s)</span>
                                                                <span>&#8369;<%= totalDailyAmount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
                                                            </div>
                                                            <div class="payroll-calc-row payroll-calc-total-row">
                                                                <span>Bonus</span>
                                                                <span>Adjustment</span>
                                                                <span>&#8369;<%= bonusPay.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
                                                            </div>
                                                            <div class="payroll-calc-row payroll-calc-total-row">
                                                                <span>Deductions</span>
                                                                <span>Adjustment</span>
                                                                <span>-&#8369;<%= deductionPay.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
                                                            </div>
                                                            <div class="payroll-calc-row payroll-calc-grand-row">
                                                                <span>Total Salary</span>
                                                                <span>Final</span>
                                                                <span>&#8369;<%= netPayAmount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></span>
                                                            </div>
                                                        </div>
                                                    <% } else { %>
                                                        <div class="payroll-calc-summary">
                                                            <span class="payroll-calc-chip">Salary: <strong>&#8369;<%= salaryAmount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></strong></span>
                                                            <span class="payroll-calc-chip">Bonus: <strong>&#8369;<%= bonusPay.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></strong></span>
                                                            <span class="payroll-calc-chip">Deductions: <strong>&#8369;<%= deductionPay.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></strong></span>
                                                            <span class="payroll-calc-chip">Total: <strong>&#8369;<%= netPayAmount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></strong></span>
                                                        </div>
                                                        <div class="payroll-calc-empty">No daily salary computation found for this payroll period.</div>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>
                                    <% }) %>
                                </td>
                                <td style="text-align: right;">
                                    <% payrollSlots.forEach((slot) => { const record = slot.record || {}; %>
                                        <div class="payroll-slot" data-payroll-slot="actions" data-pay-date="<%= slot.key %>" style="<%= defaultPayDate === slot.key ? '' : 'display:none;' %>">
                                            <div class="table-action-group">
                                                <% if (record.hasSavedRecord) { %>
                                                    <form action="/payroll/process/<%= record.id %>" method="POST" class="inline">
                                                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                                        <input type="hidden" name="employeeId" value="<%= record.employeeId %>">
                                                        <button type="submit" class="btn btn-primary" style="padding: 0.4rem 1rem; font-size: 0.75rem; border-radius: 2rem;">Process</button>
                                                    </form>
                                                    <a href="/payroll/edit/<%= record.id %>?employeeId=<%= encodeURIComponent(record.employeeId || '') %>" class="btn-action" title="Edit">
                                                        <i data-lucide="edit-3" style="width: 18px; height: 18px;"></i>
                                                    </a>
                                                    <form action="/payroll/delete/<%= record.id %>" method="POST" class="inline" onsubmit="confirmDelete(this, 'Delete Payroll Record', 'This payroll record will be removed from the saved ledger.')">
                                                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                                        <input type="hidden" name="employeeId" value="<%= record.employeeId %>">
                                                        <button type="submit" class="btn-action btn-delete" title="Delete">
                                                            <i data-lucide="trash-2" style="width: 18px; height: 18px;"></i>
                                                        </button>
                                                    </form>
                                                <% } else { %>
                                                    <span style="font-size: 0.75rem; color: var(--text-muted); white-space: nowrap;">No saved payroll yet</span>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr data-empty-state="true">
                            <td colspan="6" style="padding: 3rem; text-align: center; color: var(--text-muted); font-style: italic;">No payroll records found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        <div class="pagination-controls" style="padding: 1.5rem; display: flex; justify-content: center; gap: 0.5rem; background: rgba(255,255,255,0.02);"></div>
    </div>
</div>

<% const paidTransactionsList = Array.isArray(locals.paidTransactions) ? locals.paidTransactions : []; %>

<div class="card" style="margin-top: 1.25rem; padding: 0; overflow: hidden; border-radius: 1.5rem;">
    <div class="card-header">
        <h3>Transaction History</h3>
        <div class="search-wrapper">
            <i data-lucide="search"></i>
            <input type="text" id="transactionSearchInput" placeholder="Search Transactions...">
        </div>
    </div>

    <div class="table-responsive" style="margin-top: 0; border: none; border-radius: 0; --table-min-width: 980px;">
        <table id="payrollTransactionTable">
            <thead>
                <tr>
                    <th data-sortable="true">Timestamp</th>
                    <th data-sortable="true">Pay Date</th>
                    <th data-sortable="true">Employee</th>
                    <th data-sortable="true">Period</th>
                    <th data-sortable="true">Status</th>
                    <th data-sortable="true" style="text-align: right;">Amount</th>
                    <th style="text-align: right;">Invoice</th>
                </tr>
            </thead>
            <tbody>
                <% if (paidTransactionsList.length > 0) { %>
                    <% paidTransactionsList.forEach((row) => { const invoicePayload = row.invoice ? encodeURIComponent(JSON.stringify(row.invoice)) : ''; const issuedAtLabel = row.invoice && row.invoice.issuedAtLabel ? row.invoice.issuedAtLabel : (row.issuedAt && row.issuedAt.toDate ? row.issuedAt.toDate().toLocaleString() : 'N/A'); %>
                        <tr>
                            <td style="color: var(--text-muted); font-size: 0.85rem;"><%= issuedAtLabel %></td>
                            <td style="color: var(--text-muted); font-size: 0.85rem;">
                                <%= row.payDateLabel || ((row.paySlot === '15') ? '15th' : (row.paySlot === 'end' ? 'End of Month' : 'N/A')) %>
                            </td>
                            <td>
                                <% if (invoicePayload) { %>
                                    <button
                                        type="button"
                                        class="invoice-employee-trigger invoice-trigger"
                                        data-invoice="<%= invoicePayload %>"
                                        data-employee-name="<%= row.employeeName || (row.invoice && row.invoice.employeeName) || '' %>"
                                        data-employee-code="<%= row.employeeCode || (row.invoice && row.invoice.employeeCode) || row.employeeId || '' %>">
                                        <span class="invoice-employee-trigger__name"><%= row.employeeName || (row.invoice && row.invoice.employeeName) || 'Employee' %></span>
                                        <span class="invoice-employee-trigger__code"><%= row.employeeCode || (row.invoice && row.invoice.employeeCode) || row.employeeId || 'N/A' %></span>
                                    </button>
                                <% } else { %>
                                    <div style="font-weight: 800; color: var(--text-heading);"><%= row.employeeName || (row.invoice && row.invoice.employeeName) || 'Employee' %></div>
                                    <div style="font-size: 0.75rem; color: var(--text-muted);"><%= row.employeeCode || (row.invoice && row.invoice.employeeCode) || row.employeeId || 'N/A' %></div>
                                <% } %>
                            </td>
                            <td style="color: var(--text-muted); font-size: 0.85rem;"><%= (row.invoice && row.invoice.period) || row.period || 'N/A' %></td>
                            <td style="color: var(--text-muted); font-size: 0.85rem;">
                                <span class="payroll-transaction-status payroll-transaction-status--paid">Paid</span>
                            </td>
                            <td style="text-align: right; font-weight: 800; color: var(--text-heading); font-family: 'JetBrains Mono', 'Fira Code', monospace;">
                                &#8369;<%= Number(row.amount || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                            </td>
                            <td style="text-align: right;">
                                <% if (invoicePayload) { %>
                                    <button
                                        type="button"
                                        class="btn invoice-trigger"
                                        data-invoice="<%= invoicePayload %>"
                                        data-employee-name="<%= row.employeeName || (row.invoice && row.invoice.employeeName) || '' %>"
                                        data-employee-code="<%= row.employeeCode || (row.invoice && row.invoice.employeeCode) || row.employeeId || '' %>"
                                        style="padding: 0.35rem 0.8rem; font-size: 0.75rem; border-radius: 999px;">
                                        View Receipt
                                    </button>
                                <% } else { %>
                                    <span style="color: var(--text-muted); font-size: 0.8rem;">—</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr data-empty-state="true">
                        <td colspan="7" style="padding: 2.25rem; text-align: center; color: var(--text-muted); font-style: italic;">No saved transaction history yet.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
    <div class="pagination-controls transaction-pagination" style="padding: 1.25rem; display: flex; justify-content: center; gap: 0.5rem; background: rgba(255,255,255,0.02);"></div>
</div>

<div id="invoiceModal" class="invoice-modal" hidden>
    <div class="invoice-modal__backdrop" data-close-invoice="true"></div>
    <div class="invoice-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="invoiceModalTitle">
        <button type="button" class="invoice-modal__close" data-close-invoice="true" aria-label="Close invoice">
            <i data-lucide="x"></i>
        </button>
        <div class="invoice-receipt">
            <div class="invoice-receipt__header">
                <div>
                    <span class="invoice-receipt__eyebrow">Payroll Receipt</span>
                    <h3 id="invoiceModalTitle">Invoice</h3>
                </div>
                <div class="invoice-receipt__badge" id="invoiceStatusBadge">Paid</div>
            </div>

            <div class="invoice-receipt__meta">
                <div>
                    <span>Invoice No.</span>
                    <strong id="invoiceNumber">-</strong>
                </div>
                <div>
                    <span>Issued</span>
                    <strong id="invoiceIssuedAt">-</strong>
                </div>
                <div>
                    <span>Employee ID</span>
                    <strong id="invoiceEmployeeId">-</strong>
                </div>
                <div>
                    <span>Period</span>
                    <strong id="invoicePeriod">-</strong>
                </div>
            </div>

            <div class="invoice-receipt__section">
                <div class="invoice-receipt__line">
                    <span>Name</span>
                    <strong id="invoiceEmployeeName">-</strong>
                </div>
                <div class="invoice-receipt__line">
                    <span>Department</span>
                    <strong id="invoiceDepartment">-</strong>
                </div>
                <div class="invoice-receipt__line">
                    <span>Position</span>
                    <strong id="invoicePosition">-</strong>
                </div>
            </div>

            <div class="invoice-receipt__section">
                <div class="invoice-receipt__line">
                    <span>Salary</span>
                    <strong id="invoiceBasic">&#8369;0.00</strong>
                </div>
                <div class="invoice-receipt__line">
                    <span>Bonus</span>
                    <strong id="invoiceBonus">&#8369;0.00</strong>
                </div>
                <div class="invoice-receipt__line">
                    <span>Deductions</span>
                    <strong id="invoiceDeductions">&#8369;0.00</strong>
                </div>
            </div>

            <div class="invoice-receipt__total">
                <span>Total Salary</span>
                <strong id="invoiceAmount">&#8369;0.00</strong>
            </div>
        </div>
    </div>
</div>

<style>
    .payroll-money-chip {
        font-weight: 800;
        color: var(--text-heading);
        background: rgba(124, 58, 237, 0.08);
        display: inline-block;
        padding: 0.4rem 0.8rem;
        border-radius: 0.5rem;
        border: 1px solid var(--border-glass);
    }

    .payroll-calc-wrap {
        width: min(420px, 92vw);
        margin-left: auto;
        text-align: left;
        display: grid;
        gap: 0.55rem;
    }

    .payroll-breakdown-card {
        border: 1px solid var(--border-glass);
        border-radius: 0.85rem;
        padding: 0.75rem 0.8rem;
        background: rgba(255, 255, 255, 0.72);
        display: grid;
        gap: 0.45rem;
    }

    .payroll-breakdown-row,
    .payroll-breakdown-total {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .payroll-breakdown-row strong,
    .payroll-breakdown-total strong {
        color: var(--text-heading);
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
    }

    .payroll-breakdown-total {
        margin-top: 0.1rem;
        padding-top: 0.45rem;
        border-top: 1px solid rgba(124, 58, 237, 0.12);
        font-weight: 700;
    }

    .invoice-employee-trigger {
        width: 100%;
        text-align: left;
        border: 0;
        padding: 0;
        background: transparent;
        cursor: pointer;
        display: grid;
        gap: 0.15rem;
    }

    .invoice-employee-trigger__name {
        font-weight: 800;
        color: var(--text-heading);
        text-decoration: underline;
        text-underline-offset: 0.2em;
    }

    .invoice-employee-trigger__code {
        font-size: 0.75rem;
        color: var(--text-muted);
        text-decoration: none;
    }

    .payroll-transaction-status {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        padding: 0.2rem 0.5rem;
        border-radius: 999px;
        font-size: 0.64rem;
        font-weight: 800;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .payroll-transaction-status--pending {
        background: rgba(245, 158, 11, 0.12);
        color: #b45309;
    }

    .payroll-transaction-status--processed {
        background: rgba(59, 130, 246, 0.12);
        color: #1d4ed8;
    }

    .payroll-transaction-status--paid {
        background: rgba(22, 163, 74, 0.12);
        color: #15803d;
    }

    .payroll-calc-toggle {
        width: 100%;
        border: 1px solid var(--border-glass);
        background: rgba(255, 255, 255, 0.85);
        color: var(--accent-primary);
        font-size: 0.78rem;
        font-weight: 700;
        border-radius: 0.7rem;
        padding: 0.55rem 0.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.6rem;
        cursor: pointer;
        transition: all 0.25s ease;
        text-align: left;
    }

    .payroll-calc-toggle:hover {
        border-color: rgba(124, 58, 237, 0.35);
        box-shadow: 0 6px 16px -10px rgba(124, 58, 237, 0.45);
        transform: translateY(-1px);
    }

    .payroll-calc-chevron {
        width: 14px;
        height: 14px;
        transition: transform 0.2s ease;
        flex-shrink: 0;
    }

    .payroll-calc-toggle.is-open .payroll-calc-chevron {
        transform: rotate(180deg);
    }

    .payroll-calc-panel {
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        margin-top: 0;
        transition: max-height 0.3s ease, opacity 0.2s ease, margin-top 0.2s ease;
        border: 1px solid transparent;
        border-radius: 0.75rem;
        background: rgba(124, 58, 237, 0.03);
    }

    .payroll-calc-panel.is-open {
        max-height: 520px;
        opacity: 1;
        margin-top: 0.45rem;
        border-color: var(--border-glass);
        padding: 0.65rem;
    }

    .payroll-calc-summary {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 0.55rem;
    }

    .payroll-calc-chip {
        font-size: 0.68rem;
        color: var(--text-muted);
        border: 1px solid var(--border-glass);
        border-radius: 999px;
        padding: 0.25rem 0.55rem;
        background: rgba(255, 255, 255, 0.75);
    }

    .payroll-calc-chip strong {
        color: var(--text-heading);
        font-weight: 700;
    }

    .payroll-calc-table {
        display: grid;
        gap: 0.32rem;
    }

    .payroll-calc-row {
        display: grid;
        grid-template-columns: 1.15fr 1.3fr 0.95fr;
        gap: 0.6rem;
        align-items: center;
        font-size: 0.72rem;
        color: var(--text-muted);
        padding: 0.42rem 0.5rem;
        border-radius: 0.5rem;
        background: rgba(255, 255, 255, 0.78);
        border: 1px solid rgba(124, 58, 237, 0.08);
    }

    .payroll-calc-row span:last-child {
        text-align: right;
        font-weight: 700;
        color: var(--text-heading);
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
    }

    .payroll-calc-head {
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--text-heading);
        font-size: 0.63rem;
        background: rgba(124, 58, 237, 0.09);
    }

    .payroll-calc-empty {
        font-size: 0.74rem;
        color: var(--text-muted);
        padding: 0.35rem 0.2rem;
    }

    .invoice-modal[hidden] {
        display: none;
    }

    .invoice-modal {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .invoice-modal__backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.55);
        backdrop-filter: blur(6px);
    }

    .invoice-modal__dialog {
        position: relative;
        z-index: 1;
        width: min(760px, calc(100vw - 2rem));
        max-height: calc(100vh - 2rem);
        margin: 0;
        overflow: auto;
        border-radius: 1.5rem;
        background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,250,252,0.98) 100%);
        box-shadow: 0 30px 60px -30px rgba(15, 23, 42, 0.65);
    }

    .invoice-modal__close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        width: 2.4rem;
        height: 2.4rem;
        border-radius: 999px;
        border: 1px solid rgba(15, 23, 42, 0.08);
        background: rgba(255, 255, 255, 0.9);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .invoice-receipt {
        padding: 2rem;
        display: grid;
        gap: 1.2rem;
        color: #0f172a;
    }

    .invoice-receipt__header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        padding-bottom: 1rem;
        border-bottom: 2px dashed rgba(15, 23, 42, 0.12);
    }

    .invoice-receipt__eyebrow {
        display: block;
        font-size: 0.75rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #64748b;
        margin-bottom: 0.35rem;
    }

    .invoice-receipt__header h3 {
        margin: 0;
        font-size: 1.8rem;
    }

    .invoice-receipt__badge {
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        background: rgba(22, 163, 74, 0.12);
        color: #15803d;
        font-size: 0.78rem;
        font-weight: 800;
        text-transform: uppercase;
    }

    .invoice-receipt__meta {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.75rem;
    }

    .invoice-receipt__meta div,
    .invoice-receipt__line {
        display: grid;
        gap: 0.25rem;
    }

    .invoice-receipt__meta span,
    .invoice-receipt__line span {
        color: #64748b;
        font-size: 0.74rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .invoice-receipt__meta strong,
    .invoice-receipt__line strong {
        color: #0f172a;
        font-size: 0.92rem;
    }

    .invoice-receipt__section {
        border: 1px solid rgba(15, 23, 42, 0.08);
        border-radius: 1rem;
        padding: 1rem;
        display: grid;
        gap: 0.8rem;
        background: rgba(255, 255, 255, 0.86);
    }

    .invoice-receipt__line {
        grid-template-columns: 1fr auto;
        align-items: center;
    }

    .invoice-receipt__total {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        border-top: 2px dashed rgba(15, 23, 42, 0.12);
        padding-top: 1rem;
        font-size: 1.1rem;
        font-weight: 800;
    }

    .invoice-receipt__total strong {
        font-size: 1.6rem;
    }

    @media (max-width: 768px) {
        .payroll-calc-wrap {
            width: min(360px, 94vw);
        }

        .payroll-calc-row {
            grid-template-columns: 1fr;
            gap: 0.2rem;
        }

        .payroll-calc-head {
            display: none;
        }

        .payroll-calc-row span:last-child {
            text-align: left;
        }

        .invoice-receipt__meta {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .invoice-receipt__line {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        lucide.createIcons();

        const applyPayrollRowSelection = (row, payDate) => {
            if (!row) return;

            row.querySelectorAll('.payroll-slot[data-pay-date]').forEach((slot) => {
                slot.style.display = slot.dataset.payDate === payDate ? '' : 'none';
            });
        };

        document.querySelectorAll('.payroll-employee-row').forEach((row) => {
            const select = row.querySelector('.payroll-row-date-select');
            const initialPayDate = select ? select.value : (row.dataset.defaultPayDate || '15');

            applyPayrollRowSelection(row, initialPayDate);

            if (select) {
                select.addEventListener('change', () => {
                    applyPayrollRowSelection(row, select.value || '15');
                });
            }
        });

        if (typeof initTableManagement === 'function') {
            initTableManagement('#payrollTable', '#searchInput', '.pagination-controls', 10);
            initTableManagement('#payrollTransactionTable', '#transactionSearchInput', '.transaction-pagination', 10);
        }

        document.querySelectorAll('.payroll-calc-toggle').forEach((toggleBtn) => {
            toggleBtn.addEventListener('click', () => {
                const targetId = toggleBtn.getAttribute('data-target');
                const targetPanel = document.getElementById(targetId);
                if (!targetPanel) return;

                const willOpen = !targetPanel.classList.contains('is-open');
                targetPanel.classList.toggle('is-open', willOpen);
                toggleBtn.classList.toggle('is-open', willOpen);
                toggleBtn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
            });
        });

        const invoiceModal = document.getElementById('invoiceModal');
        const invoiceFields = {
            invoiceNumber: document.getElementById('invoiceNumber'),
            invoiceIssuedAt: document.getElementById('invoiceIssuedAt'),
            invoiceEmployeeId: document.getElementById('invoiceEmployeeId'),
            invoicePeriod: document.getElementById('invoicePeriod'),
            invoiceEmployeeName: document.getElementById('invoiceEmployeeName'),
            invoiceDepartment: document.getElementById('invoiceDepartment'),
            invoicePosition: document.getElementById('invoicePosition'),
            invoiceBasic: document.getElementById('invoiceBasic'),
            invoiceBonus: document.getElementById('invoiceBonus'),
            invoiceDeductions: document.getElementById('invoiceDeductions'),
            invoiceAmount: document.getElementById('invoiceAmount'),
            invoiceStatusBadge: document.getElementById('invoiceStatusBadge')
        };

        const formatMoney = (value) => `\u20b1${Number(value || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;

        const openInvoiceModal = (invoice) => {
            if (!invoiceModal || !invoice) return;

            invoiceFields.invoiceNumber.textContent = invoice.invoiceNumber || '-';
            invoiceFields.invoiceIssuedAt.textContent = invoice.issuedAtLabel || invoice.issuedAt || '-';
            invoiceFields.invoiceEmployeeId.textContent = invoice.employeeCode || invoice.employeeId || '-';
            invoiceFields.invoicePeriod.textContent = invoice.period || '-';
            invoiceFields.invoiceEmployeeName.textContent = invoice.employeeName || '-';
            invoiceFields.invoiceDepartment.textContent = invoice.department || '-';
            invoiceFields.invoicePosition.textContent = invoice.position || '-';
            invoiceFields.invoiceBasic.textContent = formatMoney(invoice.basic);
            invoiceFields.invoiceBonus.textContent = formatMoney(invoice.bonus);
            invoiceFields.invoiceDeductions.textContent = formatMoney(invoice.deductions);
            invoiceFields.invoiceAmount.textContent = formatMoney(invoice.amount);
            invoiceFields.invoiceStatusBadge.textContent = invoice.status || 'Paid';

            invoiceModal.hidden = false;
            document.body.style.overflow = 'hidden';
        };

        const closeInvoiceModal = () => {
            if (!invoiceModal) return;
            invoiceModal.hidden = true;
            document.body.style.overflow = '';
        };

        // Use event delegation so pagination/search DOM changes won't break receipt clicks.
        document.addEventListener('click', (event) => {
            const trigger = event.target && event.target.closest
                ? event.target.closest('.invoice-trigger[data-invoice]')
                : null;
            if (!trigger) return;

            // Make sure we handle this even if another handler stops bubbling.
            if (event && typeof event.preventDefault === 'function') event.preventDefault();

            try {
                let invoiceText = trigger.dataset.invoice || '{}';
                try {
                    invoiceText = decodeURIComponent(invoiceText);
                } catch (decodeError) {
                    // keep raw value (older payloads may already be plain JSON)
                }
                const invoice = JSON.parse(invoiceText || '{}');

                // Defensive fallback: older records may have incomplete invoice fields.
                if (!invoice.employeeName && trigger.dataset.employeeName) invoice.employeeName = trigger.dataset.employeeName;
                if (!invoice.employeeCode && trigger.dataset.employeeCode) invoice.employeeCode = trigger.dataset.employeeCode;
                if (!invoice.employeeId && trigger.dataset.employeeCode) invoice.employeeId = trigger.dataset.employeeCode;
                if (!invoice.status) invoice.status = 'Paid';

                openInvoiceModal(invoice);
            } catch (error) {
                console.error('Failed to parse invoice data:', error);
            }
        }, true);

        if (invoiceModal) {
            invoiceModal.querySelectorAll('[data-close-invoice="true"]').forEach((button) => {
                button.addEventListener('click', closeInvoiceModal);
            });
        }

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && invoiceModal && !invoiceModal.hidden) {
                closeInvoiceModal();
            }
        });

        const payrollForm = document.querySelector('.payroll-filters form');
        if (payrollForm) {
            const monthSelect = payrollForm.querySelector('select[name="month"]');
            const yearSelect = payrollForm.querySelector('select[name="year"]');
            const navigate = () => {
                const month = monthSelect ? monthSelect.value : '<%= selectedMonth %>';
                const year = yearSelect ? yearSelect.value : '<%= selectedYear %>';
                const params = new URLSearchParams(window.location.search);
                params.set('month', month);
                params.set('year', year);
                window.location.search = params.toString();
            };

            if (monthSelect) monthSelect.addEventListener('change', navigate);
            if (yearSelect) yearSelect.addEventListener('change', navigate);
        }
    });
</script>
<script src="/js/payroll-realtime.js"></script>
