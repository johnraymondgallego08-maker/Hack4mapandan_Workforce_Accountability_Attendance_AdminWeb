<div class="page-container">
    <div class="page-header">
        <div>
            <h1>Attendance Details</h1> 
            <!-- <p style="color: var(--text-muted); font-size: 0.9rem;">Track employee check-in/out times and daily status.</p> -->
        </div>
        <a href="/attendance/add" class="btn btn-primary">
            <i data-lucide="plus-circle" style="width: 18px; height: 18px;"></i>
            <span>Add Record</span>
        </a>
    </div>

    <div class="card attendance-card">
        <div class="card-header">
            <h3>Daily Logs</h3>
            <div class="filter-container">
                <div class="search-input-wrapper">
                    <i data-lucide="search" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 18px; color: #9ca3af;"></i>
                    <input type="text" id="searchInput" placeholder="Search Attendees..." class="filter-item" style="width: 100%; padding-left: 2.75rem; background: white;">
                </div>
                <select id="statusFilter" class="filter-item" data-status-column="5">
                    <option value="all">All Status</option>
                    <option value="present">Present</option>
                    <option value="late">Late</option>
                    <option value="overtime">Overtime</option>
                    <option value="absent">Absent</option>
                </select>
                <button type="button" id="downloadCSV" class="btn-csv-red">
                    <i data-lucide="download" style="width: 18px; height: 18px;"></i>
                    Export CSV
                </button>
            </div>
        </div>

        <div class="table-responsive attendance-table-container">
            <table id="attendanceTable">
                <thead>
                    <tr>
                        <th data-sortable="true" style="white-space: nowrap;">Employee</th>
                        <th data-sortable="true" style="white-space: nowrap;">Time In</th>
                        <th data-sortable="true" style="white-space: nowrap;">Time Out</th>
                        <th data-sortable="true" style="white-space: nowrap; text-align: center;">Hours</th>
                        <th data-sortable="true" style="white-space: nowrap;">Date</th>
                        <th data-sortable="true" style="white-space: nowrap; text-align: center;">Daily Status</th>
                        <th data-sortable="true" style="text-align: right;">Log Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (locals.attendance && attendance.length > 0) { %>
                        <% attendance.forEach(record => { %>
                            <tr data-attendance-id="<%= record.id || '' %>">
                                <td style="font-weight: 700; color: var(--text-heading);">
                                    <a href="/attendance/summary?employeeId=<%= record.employeeId || record.userId %>" class="employee-link" title="View Attendance Summary">
                                        <%= record.name || 'N/A' %>
                                    </a>
                                </td>
                                <td class="mono-text accent-info"><%= record.timeIn || 'N/A' %></td>
                                <td class="mono-text accent-info"><%= record.timeOut || 'N/A' %></td>
                                <td class="text-center mono-text hours-col"><%= record.hoursWorked || 'N/A' %></td>
                                <td class="date-col"><%= record.date || 'N/A' %></td>
                                <td style="text-align: center;">
                                    <% 
                                       const getStatusClass = (s) => {
                                           const stat = (s || '').toLowerCase();
                                           if(stat.includes('late')) return 'status-late';
                                           if(stat.includes('absent') || stat.includes('rejected')) return 'status-absent';
                                           if(stat.includes('leave')) return 'status-leave';
                                           if(stat.includes('overtime')) return 'status-overtime';
                                           if(stat.includes('present') || stat.includes('active') || stat.includes('timed in')) return 'status-present';
                                           return 'status-default';
                                       };
                                    %>
                                    <span class="status-badge <%= getStatusClass(record.dailyStatus) %>" style="font-size: 0.7rem; padding: 0.2rem 0.6rem;">
                                        <%= record.dailyStatus || 'Present' %>
                                    </span>
                                </td>
                                <td style="text-align: right;">
                                    <span class="status-badge <%= getStatusClass(record.status) %>">
                                        <%= record.status || 'Unknown' %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" style="padding: 3rem; text-align: center; color: var(--text-muted); font-style: italic;">No attendance records found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        <div class="pagination-controls" style="padding: 1.5rem; display: flex; justify-content: center; gap: 0.5rem; background: rgba(255,255,255,0.02);"></div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        lucide.createIcons();

        let attendanceTableManager = null;
        if (typeof initTableManagement === 'function') {
            attendanceTableManager = initTableManagement('#attendanceTable', '#searchInput', '.pagination-controls', 10, {
                statusFilterSelector: '#statusFilter'
            });
        }

        const urlParams = new URLSearchParams(window.location.search);
        const searchParam = urlParams.get('search');
        if (searchParam) {
            const searchInput = document.getElementById('searchInput');
            if (searchInput) searchInput.value = searchParam;
            if (attendanceTableManager) attendanceTableManager.refresh();
        }

        // CSV Export Functionality
        const csvBtn = document.getElementById('downloadCSV');
        if (csvBtn) {
            csvBtn.addEventListener('click', () => {
                const table = document.getElementById('attendanceTable');
                const rows = Array.from(table.querySelectorAll('tbody tr'));
                const headers = Array.from(table.querySelectorAll('thead th'))
                    .map(th => th.textContent.trim());

                const csvData = [headers.join(',')];
                
                rows.forEach(row => {
                    // Export only visible rows (respecting filters) and exclude empty state row
                    const isFiltered = row.getAttribute('data-filtered') === 'true';
                    if (!isFiltered && row.cells.length > 1) {
                        const rowData = Array.from(row.cells).map(cell => {
                            let text = cell.textContent.trim().replace(/"/g, '""');
                            // Extract text specifically from link if present (Employee column)
                            const link = cell.querySelector('.employee-link');
                            if (link) text = link.textContent.trim().replace(/"/g, '""');
                            return `"${text}"`;
                        });
                        csvData.push(rowData.join(','));
                    }
                });

                const blob = new Blob([csvData.join('\n')], { type: 'text/csv;charset=utf-8;' });
                const link = document.createElement('a');
                link.href = URL.createObjectURL(blob);
                link.setAttribute('download', `attendance_logs_${new Date().toISOString().split('T')[0]}.csv`);
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });
        }
    });
</script>

<style>
    .employee-link {
        color: inherit;
        text-decoration: none;
        transition: color 0.2s;
    }
    .employee-link:hover { color: var(--accent-info); text-decoration: underline; }
    .attendance-card {
        padding: 0; 
        overflow: hidden; 
        border-radius: 1.5rem;
    }
    .attendance-table-container {
        margin-top: 0; 
        border: none; 
        border-radius: 0; 
        --table-min-width: 1180px;
    }
    .mono-text { font-family: monospace; }
    .accent-info { color: var(--accent-info); }
    .hours-col { font-weight: 700; color: var(--text-muted); }
    .date-col { 
        white-space: nowrap; 
        color: var(--text-muted); 
        font-size: 0.85rem; 
    }

    /* Filter Layout Enhancements */
    .filter-container {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: center;
        width: 100%;
        margin-top: 1.25rem;
    }
    .filter-item {
        height: 2.75rem;
        padding: 0 0.75rem;
        border: 1.5px solid #e5e7eb;
        border-radius: 10px;
        font-size: 0.9rem;
        background: #f9fafb;
        color: #374151;
        box-sizing: border-box;
        flex: 1 1 150px;
        min-width: 0;
    }
    .search-input-wrapper {
        flex: 2 1 250px;
        position: relative;
    }
    .btn-csv-red {
        background: #dc2626;
        color: white;
        border: 1.5px solid transparent;
        height: 2.75rem;
        padding: 0 1.25rem;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        transition: all 0.2s;
        white-space: nowrap;
        box-sizing: border-box;
        flex: 0 0 auto;
        margin-bottom: 1rem;
    }
    .btn-csv-red:hover {
        opacity: 0.9;
        transform: translateY(-1px);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    /* Sticky Header Fix */
    #attendanceTable { border-collapse: separate; border-spacing: 0; }
    #attendanceTable thead th {
        position: sticky;
        top: 0;
        z-index: 20;
        background: #f9fafb;
    }

    .status-late { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }
    .status-leave { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
    .status-overtime { background: rgba(168, 85, 247, 0.12); color: #7c3aed; }
</style>
<script src="/js/attendance-realtime.js"></script>
